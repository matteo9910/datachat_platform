# ============================================================
# DataChat BI Platform — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# BLOCKING items must be configured before starting Phase 1.
# Phase-specific items can be configured before that phase begins.
#
# All phases documented: Phase 01 through Phase 07
# ============================================================


# ------------------------------------------------------------
# DATABASE — PostgreSQL 16
# ------------------------------------------------------------
# Used for: application data, metadata, Vanna training storage
# Required from: Phase 01 (BLOCKING)
# Setup: install PostgreSQL 16 from https://www.postgresql.org/download/
# Create database: createdb datachat_poc
# Connection format: postgresql://user:password@host:port/dbname

DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/datachat_poc

# Used by MCP PostgreSQL server (Anthropic official)
# Same connection string, required separately for MCP subprocess
# Required from: Phase 02
MCP_POSTGRES_CONNECTION_STRING=postgresql://postgres:yourpassword@localhost:5432/datachat_poc

# PostgreSQL individual parameters (alternative to DATABASE_URL)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=datachat_poc
POSTGRES_USER=postgres
POSTGRES_PASSWORD=yourpassword


# ------------------------------------------------------------
# SYSTEM DATABASE — Neon PostgreSQL (System Metadata)
# ------------------------------------------------------------
# Used for: application metadata (auth, sessions, audit log, brand config,
#           write whitelist, KB pairs, instructions, view/dashboard metadata)
# Required from: M1 (auth infrastructure)
# System tables are NEVER created on the client database.
# Get a free Neon database at: https://neon.tech

SYSTEM_DATABASE_URL=

# Seed admin account password (used on first run to create admin user)
SEED_ADMIN_PASSWORD=


# ------------------------------------------------------------
# OPENROUTER — Claude Sonnet 4.5 (Primary LLM)
# ------------------------------------------------------------
# Used for: NL query understanding, SQL generation assistance,
#           chart config generation, NL response synthesis
# Required from: Phase 03
# Get your key at: https://openrouter.ai/keys
# Pricing: pay-per-token, ~$3/M input tokens for Claude Sonnet 4.5
# Create account, add credits, generate API key

OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=anthropic/claude-sonnet-4-5

# Optional: site info for OpenRouter attribution headers
OPENROUTER_SITE_URL=http://localhost:5173
OPENROUTER_SITE_NAME=DataChat BI Platform POC


# ------------------------------------------------------------
# AZURE OPENAI — GPT-4.1 / GPT-5 (Secondary LLM)
# ------------------------------------------------------------
# Used for: alternative LLM provider, user-selectable in UI
# Required from: Phase 03
# Setup: Azure Portal > Azure OpenAI > Create resource
# Portal: https://portal.azure.com/#create/Microsoft.CognitiveServicesOpenAI
# After resource creation, deploy model and get endpoint/key from:
#   Azure OpenAI Studio > Deployments > your-deployment > Keys and Endpoint
# Pricing: varies by model and region, check Azure pricing calculator

AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com/
AZURE_OPENAI_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4-1
AZURE_OPENAI_API_VERSION=2024-02-01

# Azure OpenAI model for chat (primary deployment)
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4-1

# Azure OpenAI model for embeddings (if used separately)
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small


# ------------------------------------------------------------
# AZURE OPENAI — Whisper (Speech-to-Text)
# ------------------------------------------------------------
# Used for: voice input transcription (Italian + multilingual)
# Model: OpenAI Whisper via Azure AI Foundry
# Supports 99 languages including Italian
# Required from: Voice Input feature implementation

AZURE_WHISPER_ENDPOINT=https://your-resource.cognitiveservices.azure.com
AZURE_WHISPER_DEPLOYMENT_NAME=whisper
AZURE_WHISPER_API_KEY=your-whisper-api-key
AZURE_WHISPER_API_VERSION=2024-06-01


# ------------------------------------------------------------
# LLM ORCHESTRATION — Provider Selection
# ------------------------------------------------------------
# Used for: selecting the default LLM provider at startup
# Required from: Phase 03
# Options: "openrouter" | "azure_openai"

DEFAULT_LLM_PROVIDER=openrouter

# Session rolling window size (number of conversation turns to keep)
SESSION_WINDOW_SIZE=5

# LLM request timeout in seconds
LLM_TIMEOUT_SECONDS=60

# Retry configuration for LLM calls (tenacity)
LLM_MAX_RETRIES=3
LLM_RETRY_WAIT_SECONDS=2


# ------------------------------------------------------------
# VANNA 2.0 — Text-to-SQL RAG Engine
# ------------------------------------------------------------
# Used for: natural language to SQL translation via RAG
# Required from: Phase 02 (BLOCKING for core functionality)
# No external API key needed — Vanna runs locally with ChromaDB
# Model name for Vanna instance identification

VANNA_MODEL=datachat_poc
VANNA_TEMPERATURE=0.1

# Path to Vanna training data seed file
VANNA_TRAINING_SEED_PATH=./backend/data/training_seed.json


# ------------------------------------------------------------
# CHROMADB — Vector Database (embedded, local)
# ------------------------------------------------------------
# Used for: storing Vanna RAG embeddings (DDL, documentation, SQL pairs)
# Required from: Phase 02
# ChromaDB runs embedded (no external service needed)
# Persist directory stores the vector DB on disk

CHROMADB_PERSIST_DIRECTORY=./backend/data/chromadb
CHROMADB_COLLECTION_NAME=vanna_datachat


# ------------------------------------------------------------
# MCP SERVERS — Model Context Protocol
# ------------------------------------------------------------

# --- MCP PostgreSQL Server (Anthropic official) ---
# Used for: direct database inspection, schema introspection
# Required from: Phase 02
# Install: npm install -g @modelcontextprotocol/server-postgres
# Package: @modelcontextprotocol/server-postgres
# GitHub: https://github.com/modelcontextprotocol/servers/tree/main/src/postgres

MCP_POSTGRES_ENABLED=true
MCP_POSTGRES_SERVER_COMMAND=npx
MCP_POSTGRES_SERVER_ARGS=-y @modelcontextprotocol/server-postgres

# --- MCP Power BI Modeling Server (Microsoft preview) ---
# Used for: modifying Power BI .pbix files via MCP, text-to-DAX
# Required from: Phase 06
# Install: npm install -g @microsoft/powerbi-modeling-mcp
# Note: Preview package (2026), verify availability on npm registry
# Requires: Power BI Desktop installed on the machine

MCP_POWERBI_ENABLED=true
MCP_POWERBI_SERVER_COMMAND=npx
MCP_POWERBI_SERVER_ARGS=-y @microsoft/powerbi-modeling-mcp

# Path to the Power BI .pbix workspace file for MCP operations
# This file will be modified by the Power BI MCP server
MCP_POWERBI_WORKSPACE_PATH=./backend/data/powerbi/datachat_report.pbix

# MCP subprocess timeout in milliseconds
MCP_TIMEOUT_MS=30000


# ------------------------------------------------------------
# POWER BI INTEGRATION — Phase 06
# ------------------------------------------------------------
# Used for: DAX generation, .pbix file modification, preview generation
# Required from: Phase 06
# Power BI Desktop must be installed:
#   https://powerbi.microsoft.com/en-us/desktop/
# Optional: Power BI Service for publishing (not required for POC)

POWERBI_DESKTOP_PATH=C:/Program Files/Microsoft Power BI Desktop/bin/PBIDesktop.exe

# Directory for backup .pbix files before MCP modifications
POWERBI_BACKUP_DIRECTORY=./backend/data/powerbi/backups

# Maximum number of .pbix backup files to retain
POWERBI_MAX_BACKUPS=10

# Preview image format for chart snapshots
POWERBI_PREVIEW_FORMAT=png


# ------------------------------------------------------------
# FASTAPI BACKEND — Server Configuration
# ------------------------------------------------------------
# Used for: backend API server settings
# Required from: Phase 01

BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# CORS allowed origins (comma-separated for multiple)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# API prefix for all routes
API_V1_PREFIX=/api/v1

# Environment mode: "development" | "production" | "testing"
ENVIRONMENT=development

# Secret key for session signing (generate with: openssl rand -hex 32)
SECRET_KEY=change-me-generate-with-openssl-rand-hex-32


# ------------------------------------------------------------
# LOGGING — Application Logging
# ------------------------------------------------------------
# Required from: Phase 01

# Log level: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# Log format: "json" | "text"
LOG_FORMAT=text

# Log file path (leave empty to log to stdout only)
LOG_FILE_PATH=./backend/logs/datachat.log


# ------------------------------------------------------------
# DATASET — Kaggle Superstore Sales
# ------------------------------------------------------------
# Used for: populating the database with sample business data
# Required from: Phase 01 (BLOCKING for database setup)
# Download from: https://www.kaggle.com/datasets/vivek468/superstore-dataset-final
# File: Sample - Superstore.csv (~9994 rows)
# Place the file at the path below before running import_kaggle_dataset.py

DATASET_CSV_PATH=./backend/data/Sample - Superstore.csv
DATASET_TABLE_NAME=superstore_sales
DATASET_SCHEMA=public

# Whether to truncate and re-import data on each run
DATASET_REIMPORT=false


# ------------------------------------------------------------
# FRONTEND — React + Vite (VITE_ prefix required)
# ------------------------------------------------------------
# All frontend env vars MUST be prefixed with VITE_ to be accessible
# in the browser via import.meta.env.*
# Required from: Phase 07

# Backend API base URL (used by Axios client in frontend)
VITE_API_BASE_URL=http://localhost:8000/api/v1

# WebSocket URL for real-time streaming (if implemented)
VITE_WS_URL=ws://localhost:8000/ws

# Application title shown in browser tab
VITE_APP_TITLE=DataChat BI Platform

# Default LLM provider shown in UI selector
VITE_DEFAULT_LLM_PROVIDER=openrouter

# Enable debug mode in frontend (shows raw SQL, token counts, etc.)
VITE_DEBUG_MODE=false

# Maximum number of messages shown in chat history
VITE_MAX_CHAT_MESSAGES=50

# Plotly chart theme: "plotly" | "plotly_dark" | "ggplot2" | "seaborn"
VITE_CHART_THEME=plotly


# ------------------------------------------------------------
# PERFORMANCE & TUNING
# ------------------------------------------------------------
# Database connection pool settings

DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600

# Maximum SQL query execution time in seconds
SQL_QUERY_TIMEOUT=30

# Maximum number of rows returned by any SQL query
SQL_MAX_ROWS=10000

# Cache TTL for repeated identical queries (seconds, 0 = disabled)
QUERY_CACHE_TTL=300


# ------------------------------------------------------------
# FEATURE FLAGS — Enable/Disable Features
# ------------------------------------------------------------
# Useful for toggling features during development phases

# Enable Power BI MCP integration (Phase 06)
FEATURE_POWERBI_ENABLED=false

# Enable chart parameter modification UI (Phase 05)
FEATURE_PARAMETRIC_CHARTS=true

# Enable multi-LLM provider selection (Phase 03)
FEATURE_MULTI_LLM=true

# Enable query history persistence (Phase 05)
FEATURE_QUERY_HISTORY=true

# Enable Vanna RAG training endpoint (Phase 02)
FEATURE_VANNA_TRAINING=true
