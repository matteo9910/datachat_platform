# ============================================================
# DataChat BI Platform — Environment Variables per Azure VM
# ============================================================
# ISTRUZIONI:
#   1. Copia questo file come: cp backend/.env.docker backend/.env
#   2. Compila tutti i valori contrassegnati con <FILL_IN>
#   3. NON committare mai backend/.env su git
# ============================================================


# ------------------------------------------------------------
# SYSTEM DATABASE — PostgreSQL (Neon / Supabase / Azure PgSQL)
# ------------------------------------------------------------
# Database di sistema per auth, audit log, brand config, ecc.
# Le tabelle vengono create automaticamente da Alembic allo startup.
SYSTEM_DATABASE_URL=postgresql://<user>:<password>@<host>/<dbname>?sslmode=require

# Password admin iniziale (usata solo al primo avvio per creare l'utente admin)
SEED_ADMIN_PASSWORD=<FILL_IN>

# Secret key per JWT (generare con: openssl rand -hex 32)
SECRET_KEY=<FILL_IN>


# ------------------------------------------------------------
# CLIENT DATABASE — PostgreSQL (database dati business)
# ------------------------------------------------------------
# Connessione di default al database dei dati da analizzare.
# Può essere sovrascritta a runtime via UI (Setup Wizard).
DATABASE_URL=postgresql://<user>:<password>@<host>:5432/<dbname>
MCP_POSTGRES_CONNECTION_STRING=postgresql://<user>:<password>@<host>:5432/<dbname>

# Parametri individuali (alternativi a DATABASE_URL)
POSTGRES_HOST=<FILL_IN>
POSTGRES_PORT=5432
POSTGRES_DB=<FILL_IN>
POSTGRES_USER=<FILL_IN>
POSTGRES_PASSWORD=<FILL_IN>


# ------------------------------------------------------------
# OPENROUTER — Claude (LLM primario)
# ------------------------------------------------------------
OPENROUTER_API_KEY=<FILL_IN>
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=anthropic/claude-sonnet-4-5
OPENROUTER_SITE_URL=http://<VM_IP_OR_DOMAIN>
OPENROUTER_SITE_NAME=DataChat BI Platform


# ------------------------------------------------------------
# AZURE OPENAI — GPT-4.1 (LLM secondario)
# ------------------------------------------------------------
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/
AZURE_OPENAI_API_KEY=<FILL_IN>
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4-1
AZURE_OPENAI_API_VERSION=2024-02-01
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4-1
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small


# ------------------------------------------------------------
# AZURE SPEECH — Voice Input
# ------------------------------------------------------------
AZURE_SPEECH_ENDPOINT=https://<your-resource>.cognitiveservices.azure.com
AZURE_SPEECH_API_KEY=<FILL_IN>

AZURE_WHISPER_ENDPOINT=https://<your-resource>.cognitiveservices.azure.com
AZURE_WHISPER_DEPLOYMENT_NAME=whisper
AZURE_WHISPER_API_KEY=<FILL_IN>
AZURE_WHISPER_API_VERSION=2024-06-01


# ------------------------------------------------------------
# LLM ORCHESTRATION
# ------------------------------------------------------------
DEFAULT_LLM_PROVIDER=openrouter
SESSION_WINDOW_SIZE=5
LLM_TIMEOUT_SECONDS=60
LLM_MAX_RETRIES=3
LLM_RETRY_WAIT_SECONDS=2


# ------------------------------------------------------------
# VANNA RAG + CHROMADB
# ------------------------------------------------------------
VANNA_MODEL=datachat_poc
VANNA_TEMPERATURE=0.1
VANNA_TRAINING_SEED_PATH=./backend/data/training_seed.json

# NOTA: questo path viene sovrascritto da docker-compose.yml con /data/chromadb
CHROMADB_PERSIST_DIRECTORY=/data/chromadb
CHROMADB_COLLECTION_NAME=vanna_datachat


# ------------------------------------------------------------
# MCP SERVERS
# ------------------------------------------------------------
MCP_POSTGRES_ENABLED=true
MCP_POSTGRES_SERVER_COMMAND=npx
MCP_POSTGRES_SERVER_ARGS=-y @modelcontextprotocol/server-postgres
MCP_TIMEOUT_MS=30000

MCP_POWERBI_ENABLED=false


# ------------------------------------------------------------
# FASTAPI SERVER
# ------------------------------------------------------------
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# CORS: aggiungere l'IP o dominio della VM Azure
CORS_ALLOWED_ORIGINS=http://localhost,http://<VM_IP_OR_DOMAIN>

ENVIRONMENT=production


# ------------------------------------------------------------
# LOGGING
# ------------------------------------------------------------
LOG_LEVEL=INFO
LOG_FORMAT=text
# NOTA: questo path viene sovrascritto da docker-compose.yml con /data/logs/datachat.log
LOG_FILE_PATH=/data/logs/datachat.log


# ------------------------------------------------------------
# DATABASE POOL
# ------------------------------------------------------------
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600
SQL_QUERY_TIMEOUT=30
SQL_MAX_ROWS=10000
QUERY_CACHE_TTL=300


# ------------------------------------------------------------
# FEATURE FLAGS
# ------------------------------------------------------------
FEATURE_POWERBI_ENABLED=false
FEATURE_PARAMETRIC_CHARTS=true
FEATURE_MULTI_LLM=true
FEATURE_QUERY_HISTORY=true
FEATURE_VANNA_TRAINING=true
